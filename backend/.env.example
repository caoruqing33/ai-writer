# AI Writer 配置文件
# 复制此文件为 .env 并填入实际值

# DeepSeek API（必填）—— 在 https://platform.deepseek.com 免费获取
AI_API_KEY=your-deepseek-api-key-here
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# 数据库（默认 SQLite，无需修改）
DATABASE_URL=sqlite:///./ai_writer.db

# JWT 认证配置（生产环境请用随机字符串）
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 公开注册开关（"true" 或 "false"）
REGISTRATION_ENABLED=true
